<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="MeuPrimeiroApp.Views.ListaProdutos"
			 Title="Minhas Compras">
		
		<ContentPage.ToolbarItems>
			<ToolbarItem Text="Somar" />
			<ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />
			<ToolbarItem Text="Relatório" Clicked="BtnVerRelatorio_Clicked" />
		</ContentPage.ToolbarItems>
		
		<ContentPage.Resources>
			<ResourceDictionary>			
				<Style TargetType="Label">
					<Setter Property="VerticalTextAlignment" Value="Center" />
				</Style>		
			</ResourceDictionary>
		</ContentPage.Resources>
		
		<StackLayout>
			<SearchBar x:Name="txt_search" 
				Margin="-15, 0, 0, 0"
                Placeholder="Busca de Produtos"
                TextChanged="txt_search_TextChanged"/>
				
			<Frame Padding="0"  Margin="10" VerticalOptions="FillAndExpand">
				<ListView x:Name="lst_produtos"
					IsPullToRefreshEnabled="True"
					Refreshing="lst_produtos_Refreshing"
					ItemSelected="lst_produtos_ItemSelected">
				<ListView.Header>
					<Grid ColumnDefinitions="40, *, 80, 90, 80, 50, 100"
						  BackgroundColor="{StaticResource Gray100}">
						<Label Grid.Column="0" Text="ID" Padding="5" FontAttributes="Bold" />
						<Label Grid.Column="1" Text="Descrição" FontAttributes="Bold" />
						<Label Grid.Column="2" Text="Categoria" FontAttributes="Bold" />
						<Label Grid.Column="3" Text="Preço" FontAttributes="Bold" />
						<Label Grid.Column="4" Text="Data" FontAttributes="Bold" />
						<Label Grid.Column="5" Text="Qnt" FontAttributes="Bold" />
						<Label Grid.Column="6" Text="Total" FontAttributes="Bold" />
					</Grid>
				</ListView.Header>
				<ListView.ItemTemplate>
					<DataTemplate>
						<ViewCell>
							<ViewCell.ContextActions>
								<MenuItem Text="Remover" Clicked="MenuItem_Clicked" />
							</ViewCell.ContextActions>
							<Grid ColumnDefinitions="40, *, 80, 90, 80, 50, 100">
								<Label Grid.Column="0" Text="{Binding Id}" Padding="5" />
								<Label Grid.Column="1" Text="{Binding Descricao}" LineBreakMode="TailTruncation" />
								<Label Grid.Column="2" Text="{Binding Categoria}" />
								<Label Grid.Column="3" Text="{Binding Preco, StringFormat='{}{0:c}'}" />
								<Label Grid.Column="4" Text="{Binding DataCadastro, StringFormat='{0:dd/MM/yy}'}" FontSize="12" VerticalOptions="Center" />
								<Label Grid.Column="5" Text="{Binding Quantidade}" />
								<Label Grid.Column="6" Text="{Binding Total, StringFormat='{}{0:c}'}" HorizontalTextAlignment="End" />
							</Grid>
						</ViewCell>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
			</Frame>
		</StackLayout>
</ContentPage>